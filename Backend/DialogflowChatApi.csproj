<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DialogflowChatApi</RootNamespace>
    <AssemblyName>DialogflowChatApi</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Google Dialogflow ES client library - calls Dialogflow via REST/gRPC -->
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
    <PackageReference Include="Google.Cloud.Dialogflow.V2" Version="4.26.0" />

    <!-- Swagger/OpenAPI documentation for the webhook endpoint -->
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

</Project>
