# Path to your Google Cloud service account JSON key file.
# Get one from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant it the "Dialogflow API Client" role.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/service-account-key.json

# Your Google Cloud project ID (must match the one in appsettings.json)
GOOGLE_CLOUD_QUOTA_PROJECT=your-gcp-project-id